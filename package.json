{
  "name": "seat-booking-system",
  "version": "1.0.0",
  "description": "Office seat booking system for hybrid work",
  "main": "backend/server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node backend/server.js",
    "client": "cd frontend && npm run dev",
    "install-all": "npm install && cd frontend && npm install && cd .."
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
